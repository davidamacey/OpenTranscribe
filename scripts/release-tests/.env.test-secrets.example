# Release-test secrets template.
# Copy this to .env.test-secrets (gitignored) and fill in HUGGINGFACE_TOKEN.
# All other keys are optional — leave blank to skip the related assertions.

# Required for PyAnnote diarization model download
HUGGINGFACE_TOKEN=

# Optional LLM provider configuration (skipped if blank)
LLM_PROVIDER=
VLLM_BASE_URL=
VLLM_API_KEY=
VLLM_MODEL_NAME=
OPENAI_API_KEY=
OPENAI_MODEL_NAME=
OLLAMA_BASE_URL=
OLLAMA_MODEL_NAME=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_NAME=
OPENROUTER_API_KEY=
OPENROUTER_MODEL_NAME=
